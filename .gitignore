# Test fixtures (local only, not for distribution)
app/matlab-bridge/test_ws_model.slx
app/matlab-bridge/workspace.mat

# All test .slx/.slxc files (local testing only)
app/*.slx
app/*.slxc
app/matlab-bridge/*.slx
app/matlab-bridge/*.slxc
app/matlab-bridge/*.mat
app/matlab-bridge/*.bak
app/matlab-bridge/'out.mat'
*.bak

